{
  "name": "@gameforge/gameforge-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "dotenv -e .env -- prisma generate",
    "prisma:push": "dotenv -e .env -- prisma db push",
    "ingest": "tsx src/scripts/rebuild-index.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^13.1.0",
    "@langchain/community": "^0.3.33",
    "@langchain/openai": "^0.3.17",
    "@langchain/textsplitters": "^0.1.0",
    "@prisma/client": "^6.7.0",
    "ai": "^4.3.16",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.0",
    "hnswlib-node": "^3.0.0",
    "koa": "^2.16.1",
    "koa-bodyparser": "^4.4.1",
    "koa-static": "^5.0.0",
    "mime-types": "^2.1.35",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^3.0.0",
    "@types/koa__router": "^12.0.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.1",
    "dotenv-cli": "^7.4.2",
    "prisma": "^6.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "volta": {
    "node": "20.20.2",
    "npm": "10.9.8"
  }
