generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  PLANNING
  DEVELOPING
  DONE
}

enum MessageRole {
  user
  assistant
  system
}

enum AssetType {
  PLAN
  CODE
  IMAGE
  BUILD
}

model User {
  id           BigInt    @id @default(autoincrement())
  email        String    @unique @db.VarChar(320)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  displayName  String?   @map("display_name") @db.VarChar(200)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  sessions     Session[]

  @@map("users")
}

model Session {
  id          BigInt        @id @default(autoincrement())
  sessionUuid String        @unique @default(uuid()) @db.Uuid @map("session_uuid")
  name        String        @default("新游戏项目")
  status      SessionStatus @default(PLANNING)
  rootDir     String        @map("root_dir")
  userId      BigInt?       @map("user_id")
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages    Message[]
  assets      GameAsset[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@map("session")
}

model Message {
  id            BigInt      @id @default(autoincrement())
  sessionId     BigInt      @map("session_id")
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role          MessageRole
  content       String      @db.Text
  isGameRelated Boolean?    @map("is_game_related")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("message")
}

model GameAsset {
  id        BigInt    @id @default(autoincrement())
  sessionId BigInt    @map("session_id")
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      AssetType
  fileName  String    @map("file_name")
  filePath  String    @map("file_path")
  content   Json?     @db.JsonB
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([sessionId, type, createdAt])
  @@map("game_asset")
}
